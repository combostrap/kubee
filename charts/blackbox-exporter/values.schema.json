                                "type": "string"
                              }
                            },
                            "required": [
                              "expect"
                            ],
                            "type": "object"
                          }
                        ],
                        "required": []
                      },
                      "required": [],
                      "title": "query_response",
                      "type": "array"
                    },
                    "tls": {
                      "default": true,
                      "required": [],
