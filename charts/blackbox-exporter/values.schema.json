                          "type": "boolean"
                        }
                      },
                      "required": [
                        "insecure_skip_verify"
                      ],
                      "title": "tls_config",
                      "type": "object"
                    }
                  },
                  "required": [
                    "preferred_ip_protocol",
                    "query_response",
                    "tls",
                    "tls_config"
