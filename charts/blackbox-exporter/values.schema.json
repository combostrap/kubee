                  "required": [
                    "preferred_ip_protocol"
                  ],
                  "title": "http",
                  "type": "object"
                },
                "prober": {
                  "default": "http",
                  "required": [],
                  "title": "prober",
                  "type": "string"
                }
              },
              "required": [
                "http",
                "prober"
              ],
              "title": "http_2xx",
              "type": "object"
            },
            "http_post_2xx": {
              "properties": {
                "http": {
                  "properties": {
                    "method": {
                      "default": "POST",
                      "required": [],
