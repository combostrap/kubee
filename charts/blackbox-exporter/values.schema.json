              "required": [
                "prober",
                "tcp"
              ],
              "title": "pop3s_banner",
              "type": "object"
            },
            "ssh_banner": {
              "properties": {
                "prober": {
                  "default": "tcp",
                  "required": [],
                  "title": "prober",
                  "type": "string"
