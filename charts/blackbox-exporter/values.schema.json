                                "type": "string"
                              }
                            },
                            "required": [
                              "expect"
                            ],
                            "type": "object"
                          }
                        ],
                        "required": []
                      },
                      "required": [],
                      "title": "query_response",
                      "type": "array"
                    }
                  },
                  "required": [
                    "preferred_ip_protocol",
                    "query_response"
                  ],
                  "title": "tcp",
                  "type": "object"
                }
              },
              "required": [
                "prober",
                "tcp"
              ],
              "title": "ssh_banner",
              "type": "object"
            },
            "tcp_connect": {
              "properties": {
                "prober": {
                  "default": "tcp",
                  "required": [],
                  "title": "prober",
                  "type": "string"
                },
                "tcp": {
                  "properties": {
                    "preferred_ip_protocol": {
                      "default": "ip4",
                      "required": [],
                      "title": "preferred_ip_protocol",
                      "type": "string"
                    }
                  },
                  "required": [
                    "preferred_ip_protocol"
                  ],
                  "title": "tcp",
                  "type": "object"
                }
              },
              "required": [
                "prober",
                "tcp"
              ],
              "title": "tcp_connect",
              "type": "object"
            }
          },
          "required": [
            "http_2xx",
            "http_post_2xx",
            "irc_banner",
            "pop3s_banner",
            "ssh_banner",
            "tcp_connect"
          ],
          "title": "modules",
          "type": "object"
        }
      },
      "required": [
        "modules"
      ],
      "title": "conf",
      "type": "object"
    },
    "enabled": {
      "default": false,
      "description": "Boolean to indicate that this chart is or will be installed in the cluster",
      "required": [],
      "title": "Enabled",
      "type": "boolean"
    },
    "global": {
      "description": "Global values are values that can be accessed from any chart or subchart by exactly the same name.",
      "required": [],
      "title": "global",
      "type": "object"
    },
    "hostname": {
      "default": "",
      "description": "The public hostname (an ingress is created if not empty)",
      "format": "hostname",
      "required": [],
