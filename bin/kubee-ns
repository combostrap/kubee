#!/usr/bin/env bash
set -Eeuo pipefail


synopsis(){
    cat << EOF

  Get, set, backup or restore namespaces

  \`\`\`bash
  kubee [kubee options] ns command [args]
  \`\`\`

  where:
  * \`command\` can be:
    * \`backup\`  - Backup all namespaces into the KUBEE_BACKUP_DIR
    * \`get\`     - Show the current connection namespace in KUBECONFIG
    * \`restore\` - Restore all namespaces from the KUBEE_BACKUP_DIR
    * \`set\`     - Set the current namespace in KUBECONFIG
EOF

}

set_ns(){
  local NS_CURRENT=${1}
  # Set or Get
  echo::info "Setting the current namespace to $NS_CURRENT"
  echo::eval "kubectl config set-context --current --namespace=$NS_CURRENT"
  echo::success "Done"
  exit
}

# Synopsis
if [[ "${1:-}" == "synopsis" ]]; then
  synopsis
  exit
fi

# Get the command
COMMAND=${1:-}
if [ "$COMMAND" = "" ]; then
  doc::help
  echo::err "A command is mandatory"
  exit 1
fi

echo::debug "Command Name: $COMMAND"
# Remove the command argument from the argument list
shift

BACKUP_PATH="$KUBEE_BACKUP_DIR/$(date +%Y%m%d)-namespaces.json"

case "$COMMAND" in
  "set")
    set_ns "$@"
    ;;
  "get")
    echo::eval "kubectl config view --minify --output 'jsonpath={..namespace}'"
    ;;
  "backup")
    kubee::set_kubeconfig_env
    if ! echo::eval "kubectl get -ojson namespace >| $BACKUP_PATH"; then
      echo::err "Error on namespace backup"
      exit 1;
    fi
    echo::success "Namespace are available at $BACKUP_PATH"

    ;;
  "restore")
    kubee::set_kubeconfig_env
    # Note: `.metadata.annotations["kubectl.kubernetes.io/last-applied-configuration"] = (. | tostring)` is to delete this
          #warning:
    # Warning: resource namespaces/vault is missing the kubectl.kubernetes.io/last-applied-configuration annotation which is required by kubectl apply.
    # kubectl apply should only be used on resources created declaratively by either kubectl create --save-config or kubectl apply.
    #The missing annotation will be patched automatically.

    # Walk start at list and goes though all levels
    jq 'walk(if type == "object" and has("metadata") then .metadata |= (del(.uid) | del(.resourceVersion) | .annotations["kubectl.kubernetes.io/last-applied-configuration"] = (. | tostring) ) else . end)' "$BACKUP_PATH" | kubectl apply -f -

    ;;
  *)
    doc::help synopsis
    echo::err "Command $COMMAND is unknown"
    exit 1
    ;;
esac






