#!/bin/bash


# shellcheck source=./bashlib-doc.sh
source "bashlib-doc.sh"

synopsis(){

  echo "Usage:"
  echo ''
  echo 'Return kubernetes certs in plain text'
  echo ''
  echo '```bash'
  # shellcheck disable=SC2005
  echo "kubee [kubee options] cert command [args]"
  echo '```'
  echo "where: command may be:"
  # shellcheck disable=SC2016
  echo '  * `backup`     : Backup the cert resources (cert manager resources and issued tls cert)'
  # shellcheck disable=SC2016
  echo '  * `cluster-tls` : Print the TLS cert of the API Server'
  # shellcheck disable=SC2016
  echo '  * `config-client` : Print the client certificate chain found in the kubeconfig file'
  # shellcheck disable=SC2016
  echo '  * `config-certificate-authority` : Print the cluster certificate authority in the kubeconfig file (certificate-authority-data)'
  # shellcheck disable=SC2016
  echo '  * `restore`     : Restore a backup'
  # shellcheck disable=SC2016
  echo '  * `secret-tls` : Print a tls certificate stored in a secret in plain text'
  # shellcheck disable=SC2016
  echo '  * `secret-ca`  : Print a ca certificate stored in a secret in plain text'

}

secret_synopsis(){

  echo "Usage:"
  echo ''
  echo 'Return the certs in plain text from a Kubernetes secret'
  echo ''
  echo '```bash'
  # shellcheck disable=SC2005
  echo "$(basename "$0") secret [-n|--namespace namespace] name"
  echo '```'
  echo "where: command may be:"
  # shellcheck disable=SC2016
  echo '  * `n` : The namespace (default to KUBEE_CONNECTION_NAMESPACE)'
  # shellcheck disable=SC2016
  echo '  * `name` : The secret name'
  # shellcheck disable=SC2016
  echo '  * `-t|--type` : The type of cert in the secret: tls or ca cert'
  # shellcheck disable=SC2016
  echo '  * `-p|--public-key` : Print only the public key in pem format'

}

restore(){

  BACKUP_FILE=${1:-$DEFAULT_BACKUP_FILE}
  BACKUP_TARGET="$KUBEE_BACKUP_DIR/$BACKUP_FILE"
  RESTORE_TARGET="$KUBEE_BACKUP_DIR/$(date +%Y%m%d)-cert-all-restore.json"

  # Note: `.metadata.annotations["kubectl.kubernetes.io/last-applied-configuration"] = (. | tostring)`
  # is to delete this warning:
  # Warning: resource namespaces/vault is missing the kubectl.kubernetes.io/last-applied-configuration annotation which is required by kubectl apply.
  # kubectl apply should only be used on resources created declaratively by either kubectl create --save-config or kubectl apply.
  #The missing annotation will be patched automatically.

  # import without the uid
  jq 'walk(if type == "object" and has("metadata") then .metadata |= (del(.uid) | del(.resourceVersion) | .annotations["kubectl.kubernetes.io/last-applied-configuration"] = (. | tostring) ) else . end)' "$BACKUP_TARGET" | \
  # no kube-system
  jq '.items |= map(select((.metadata.namespace // "") != "kube-system"))' | \
  jq '.items |= map(select((.spec.dnsNames // []) | any(test("sslip\\.io|nip\\.io")) | not))' | \
  # We don't backup cert that are related to the IP (ie sslip.io and nip.io)
  # sslip/nip.io cert
  # for the cert def
  jq '.items |= map(select((.spec.dnsNames // []) | any(test("sslip\\.io|nip\\.io")) | not))' | \
  # for the cert tls
  jq '.items |= map(select((.metadata.annotations."cert-manager.io/common-name" // "") | test("sslip\\.io|nip\\.io") | not) )' >| "$RESTORE_TARGET"
  if ! kubectl apply -f "$RESTORE_TARGET"; then
    echo::err "Error while trying to restore $RESTORE_TARGET"
    exit 1
  fi
  echo::success "The restore was successful"
  echo::success "  * The restored file can be seen at $RESTORE_TARGET"

}

backup(){
  BACKUP_TARGET="$KUBEE_BACKUP_DIR/$DEFAULT_BACKUP_FILE"

  # Backup the definitions
  CERT_MANAGER_BACKUP_TARGET="$KUBEE_BACKUP_DIR/$(date +%Y%m%d)-cert-manager.json"
  if ! kubectl get --all-namespaces -ojson issuer,clusterissuer,cert >| "$CERT_MANAGER_BACKUP_TARGET"; then
    echo::err "Error during cert manager backup"
    exit 1
  fi

  # Backup the issued certs
  TLS_CERT_BACKUP_TARGET="$KUBEE_BACKUP_DIR/$(date +%Y%m%d)-cert-tls-secret.json"
  if ! kubectl get secrets -A -o json \
    | jq '.items |= map(select( .type=="kubernetes.io/tls") )' \
    >| "$TLS_CERT_BACKUP_TARGET"; then
      echo::err "Error during tls cert secret backup"
      exit 1
  fi

  if ! jq -s '{
            apiVersion: "v1",
            kind: "List",
            items: (.[0].items + .[1].items)
          }' "$CERT_MANAGER_BACKUP_TARGET" "$TLS_CERT_BACKUP_TARGET" >| "$BACKUP_TARGET"; then
      echo::err "Error during creation of the combined backup"
      exit 1
  fi

  echo::success "Cert Backup created at ($BACKUP_TARGET). Concatenation of:"
  echo::success "  * Cert Manager Resources - issuers and cert ($CERT_MANAGER_BACKUP_TARGET)"
  echo::success "  * Issued Tls Cert        - tls secret       ($TLS_CERT_BACKUP_TARGET)"

}

HELP=${1:-}
if [[ $HELP == "synopsis" ]]; then
  doc::help synopsis
  exit
fi

if [[ $HELP =~ -h|--help|help ]]; then
  doc::help synopsis
  exit
fi

# Print the CA and TLS cert of a secret in plain text
function print_cert_secret(){


  local SECRET_NAME=""
  local SECRET_NAMESPACE=${KUBEE_CONNECTION_NAMESPACE}
  local TYPE_CERT="tls"
  local PRINT_OBJECT="cert"
  # The get secret command
  # no quote in jsonpath, not jsonpath='{.data.tls\.crt}' otherwise we get the quotes '' in the output
  local GET_TLS_SECRET_COMMAND=("kubectl" "get" "secret" )
  local args
  if ! args=$(getopt -l "namespace:,type:,public-key" -o "n:t:p" -- "$@"); then
    echo::err "Error while parsing the option"
    return 1
  fi
  # eval set to set the positional arguments back to $args
  eval set -- "$args"
  while [[ $# -gt 0 ]]
  do
     case "$1" in
      "-n"|"--namespace")
        shift
        SECRET_NAMESPACE="$1"
        shift
        ;;
      "-t"|"--type")
        shift
        TYPE_CERT="$1"
        shift
        ;;
      "-p"|"--public-key")
        PRINT_OBJECT="public-key"
        shift
        ;;
      "--")
        shift
        ;;
      *)
        SECRET_NAME="$1"
        break
     esac
  done

  GET_TLS_SECRET_COMMAND+=("-o" "jsonpath=\"{.data.$TYPE_CERT\.crt}\"")
  GET_TLS_SECRET_COMMAND+=("-n" "$SECRET_NAMESPACE")

  if [ "$SECRET_NAME" == "" ]; then
    doc::help secret_synopsis
    echo::err "A secret name is mandatory"
    return 1
  fi
  GET_TLS_SECRET_COMMAND+=("$SECRET_NAME")

  local CERT
  CERT=$(echo::eval "${GET_TLS_SECRET_COMMAND[*]} | base64 -d" )
  case "$PRINT_OBJECT" in
    "cert")
    echo "Cert $SECRET_NAME/$TYPE_CERT.cert: Print all"
    # <() is a https://en.wikipedia.org/wiki/Process_substitution to give a file (ie URI)
    openssl storeutl -noout -text <(echo "$CERT")
    ;;
    "public-key")
    echo "Cert $SECRET_NAME/$TYPE_CERT.cert: Print public key in pem format"
    openssl x509 -pubkey -noout <<< "$CERT"
    ;;
    *)
      echo:err "Print object $PRINT_OBJECT is unknown"
      return 1
  esac




}

# The client cert for client authentication
function print_cert_client_kubeconfig(){
  # openssl storeutl permits to read a bundle. Take a file as input
  # <() is a https://en.wikipedia.org/wiki/Process_substitution to give a file (ie URI)
  openssl storeutl -noout -text <(kubectl config view --minify --raw --output 'jsonpath={..user.client-certificate-data}' | base64 -d)
}

# The CA that signed the TLS cert
function print_cert_cluster_kubeconfig(){
  # openssl storeutl permits to read a bundle. Take a file as input
  # <() is a https://en.wikipedia.org/wiki/Process_substitution to give a file (ie URI)
  openssl storeutl -noout -text <(kubectl config view --minify --raw --output 'jsonpath={..cluster.certificate-authority-data}' | base64 -d)
}

function print_cert_cluster_tls(){
  local SERVER_URL
  SERVER_URL=$(kubectl config view --minify --raw --output 'jsonpath={..cluster.server}')
  local SERVER_WITHOUT_HTTPS
  SERVER_WITHOUT_HTTPS="${SERVER_URL#https://}"
  openssl s_client -connect "$SERVER_WITHOUT_HTTPS" -showcerts </dev/null 2>/dev/null | openssl x509 -noout -text
}


COMMAND=${1:-}
if [ "$COMMAND" == "" ]; then
    doc::help synopsis
    echo::err "A command is mandatory"
    exit 1
fi
shift

# This is a kubectl wrapper command - set kubeconfig
kubee::set_kubeconfig_env

DEFAULT_BACKUP_FILE="$(date +%Y%m%d)-cert-all.json"


case "$COMMAND" in
  "config-client")
    print_cert_client_kubeconfig
    ;;
  "config-certificate-authority")
    print_cert_cluster_kubeconfig
    ;;
  "cluster-tls")
    print_cert_cluster_tls
    ;;
  "secret-ca")
    print_cert_secret -t "ca" "$@"
    # see also
    # kubectl describe certificate xxxx
    ;;
  "secret-tls")
    print_cert_secret -t "tls" "$@"
    # see also
    # kubectl describe certificate xxxx
    ;;
  "backup")
    mkdir -p "$KUBEE_BACKUP_DIR"
    backup "$@"
    ;;
  "restore")
    restore "$@"
    ;;
  *)
    doc::help synopsis
    echo::err "command $COMMAND not found"
    exit 1
esac
